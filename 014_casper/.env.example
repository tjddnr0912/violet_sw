# === Korea Investment Securities (KIS) API ===
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443  # 모의투자
# KIS_BASE_URL=https://openapi.koreainvestment.com:9443    # 실전투자

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Operation ===
TRADING_MODE=paper          # paper | live | backtest
TEST_MODE=off               # on | off (live but 1 share only)
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
TIMEZONE=US/Eastern

# === Data Collection (Parquet 5-min bar store) ===
DATA_COLLECTION=off            # on | off
DATA_COLLECTION_BACKFILL=on    # cold-start yfinance backfill for last 60d

# === ICT Phase 1 — Killzone + Displacement (off by default) ===
# ICT_KILLZONE_ENABLED=on
# ICT_ALLOWED_KILLZONES=AM_MACRO         # CSV: AM_MACRO,AM_LATE,...
# ICT_REQUIRE_DISPLACEMENT=on
# ICT_DISP_ATR_MULT=1.0                  # body must be ≥ ATR(14) * this
# ICT_DISP_MAX_WICK=0.50                 # max wick / total
# ICT_DISP_PREV_MULT=1.5                 # body ≥ prev-5-bar mean body × this

# === ICT Phase 2 — Sweep + CHoCH (off by default) ===
# ICT_REQUIRE_SWEEP_CHOCH=on
# ICT_SWEEP_LOOKBACK=6                   # bars to scan for sweep
# ICT_CHOCH_LOOKBACK=6                   # bars to scan for CHoCH after sweep
# ICT_SWEEP_MIN_BREACH_PCT=0.0005        # wick must pierce by ≥ 0.05%
# ICT_SWEEP_MIN_WICK_RATIO=0.60          # pin-bar wick / total

# === ICT Phase 3 — Bearish FVG + Daily Bias (fully integrated) ===
# ICT_BEAR_FVG_FOR_SQQQ=on               # QQQ bearish setup → SQQQ Long mapping
# ICT_DAILY_BIAS_SKIP_NEUTRAL=on         # skip days with neutral daily bias

# === ICT Phase 4 — OTE / Breaker / NQ / Multi-TF (all off by default) ===
# ICT_USE_MULTI_TF_SL=on                 # 1-min swing for tighter SL
# ICT_MTF_LOOKBACK_MIN=15                # 1-min lookback window
# ICT_USE_OTE=on                         # Fibonacci entry (replaces FVG mid)
# ICT_FIB_LEVEL=0.705                    # 0.618 / 0.705 / 0.79
# ICT_REQUIRE_UNICORN=on                 # Breaker ∩ FVG overlap required
# ICT_USE_POWER_OF_3=on                  # NQ Judas Swing → bias ±1
# ICT_BULL_FVG_FOR_TQQQ=on               # QQQ bull → TQQQ Long (symmetric mapping)
